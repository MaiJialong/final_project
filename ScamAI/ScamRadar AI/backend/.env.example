# ── ScamRadar AI backend configuration ──────────────────────────────
# Copy to .env and fill in. Never commit real secrets.

# Postgres (pgvector-enabled image recommended: pgvector/pgvector:pg16)
DATABASE_URL=postgresql+psycopg://scamradar:scamradar@localhost:5432/scamradar

# MiniMax (OpenAI-compatible Chat Completions endpoint)
MINIMAX_API_KEY=sk-replace-me
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_CHAT_MODEL=MiniMax-M3
MINIMAX_IMAGE_MODEL=image-01
MINIMAX_EMBED_MODEL=embo-01

# Embedding dimensionality (must match the vector(...) columns in schema.sql)
EMBEDDING_DIM=1536

# Where generated defensive report assets are written
ASSET_OUTPUT_DIR=./generated_assets

# Set to 1 to use deterministic offline stubs instead of calling MiniMax
# (useful for local dev / CI without API keys)
OFFLINE_MODE=0
